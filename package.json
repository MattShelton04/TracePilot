{
  "name": "tracepilot",
  "version": "0.1.0",
  "private": true,
  "description": "Visualize, audit, and inspect GitHub Copilot CLI sessions",
  "scripts": {
    "dev": "pnpm --filter @tracepilot/desktop dev",
    "build": "pnpm --filter @tracepilot/desktop build",
    "build:cli": "pnpm --filter @tracepilot/cli build",
    "cli": "tsx apps/cli/src/index.ts",
    "tauri": "pnpm --filter @tracepilot/desktop tauri",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@fontsource-variable/inter": "^5.2.8",
    "tsx": "^4.21.0"
  }
}
