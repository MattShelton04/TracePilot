{
  "name": "tracepilot",
  "version": "0.6.7",
  "private": true,
  "author": "Matt Shelton (@MattShelton04)",
  "license": "GPL-3.0-or-later",
  "description": "Visualize, audit, and inspect GitHub Copilot CLI sessions",
  "homepage": "https://github.com/MattShelton04/TracePilot",
  "keywords": [
    "github-copilot",
    "cli",
    "tauri",
    "rust",
    "vue",
    "analytics",
    "orchestration"
  ],
  "scripts": {
    "start": "pnpm install && pnpm tauri dev --no-watch",
    "dev": "pnpm --filter @tracepilot/desktop dev",
    "build": "pnpm --filter @tracepilot/desktop build",
    "build:cli": "pnpm --filter @tracepilot/cli build",
    "cli": "tsx apps/cli/src/index.ts",
    "tauri": "pnpm --filter @tracepilot/desktop tauri",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check:hex": "node scripts/check-no-hex-colors.mjs",
    "check:emoji": "node scripts/check-no-emoji-in-templates.mjs",
    "check:backdrop": "node scripts/check-no-backdrop-filter.mjs",
    "check:zindex": "node scripts/check-z-index-tokens.mjs",
    "check:spacing": "node scripts/check-spacing-grid.mjs",
    "check:design-system": "node scripts/check-no-hex-colors.mjs && node scripts/check-no-emoji-in-templates.mjs && node scripts/check-no-backdrop-filter.mjs && node scripts/check-z-index-tokens.mjs",
    "gen:bindings": "cargo run -p tracepilot-tauri-bindings --bin gen-bindings",
    "clean": "pnpm -r clean",
    "prepare": "lefthook install || exit 0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@fontsource-variable/inter": "catalog:",
    "playwright-core": "^1.61.1",
    "rimraf": "^6.1.3",
    "tsx": "catalog:"
  }
}
