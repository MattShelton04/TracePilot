{
  "name": "@tracepilot/ui",
  "version": "0.6.3",
  "private": true,
  "description": "Shared Vue UI components for TracePilot",
  "author": "Matt Shelton (@MattShelton04)",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/MattShelton04/TracePilot",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./src/styles/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "vrt": "playwright test --config=playwright-ct.config.ts",
    "vrt:update": "playwright test --config=playwright-ct.config.ts --update-snapshots",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "vue-router": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@tracepilot/types": "workspace:*",
    "dompurify": "^3.3.3",
    "markdown-it": "^14.1.1",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@playwright/experimental-ct-vue": "^1.48.0",
    "@playwright/test": "^1.48.0",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/compiler-dom": "^3.5.0",
    "@vue/test-utils": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-router": "^4.6.4",
    "vue-tsc": "catalog:"
  }
}
