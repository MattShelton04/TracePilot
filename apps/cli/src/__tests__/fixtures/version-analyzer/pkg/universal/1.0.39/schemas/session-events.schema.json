{
  "$ref": "#/definitions/SessionEvent",
  "definitions": {
    "SessionEvent": {
      "anyOf": [{ "$ref": "#/definitions/StartEvent" }, { "$ref": "#/definitions/HeartbeatEvent" }]
    },
    "StartEvent": {
      "type": "object",
      "properties": {
        "type": { "const": "session.start" },
        "ephemeral": { "const": true },
        "data": { "$ref": "#/definitions/StartData" }
      },
      "required": ["type", "data"]
    },
    "StartData": {
      "type": "object",
      "description": "Session start payload.",
      "properties": {
        "copilotVersion": { "type": "string" },
        "turnCount": { "type": "integer" }
      },
      "required": ["copilotVersion"]
    },
    "HeartbeatEvent": {
      "type": "object",
      "properties": {
        "type": { "const": "session.heartbeat" },
        "ephemeral": { "type": "boolean" },
        "data": {
          "type": "object",
          "properties": {
            "latencyMs": { "type": "number" }
          },
          "required": ["latencyMs"]
        }
      },
      "required": ["type", "data"]
    }
  }
}
