{
  "name": "@tracepilot/cli",
  "version": "0.6.2",
  "private": true,
  "description": "TracePilot CLI - inspect Copilot sessions from your terminal",
  "author": "Matt Shelton (@MattShelton04)",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/MattShelton04/TracePilot",
  "type": "module",
  "bin": {
    "tracepilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tracepilot/types": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
