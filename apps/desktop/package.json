{
  "name": "@tracepilot/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "TracePilot desktop application — Tauri + Vue",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "set \"PATH=%USERPROFILE%\\\\.cargo\\\\bin;%PATH%\" && tauri",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tracepilot/types": "workspace:*",
    "@tracepilot/client": "workspace:*",
    "@tracepilot/ui": "workspace:*",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vue-tsc": "^2.2.0"
  }
}
