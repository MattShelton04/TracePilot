{
  "identifier": "default",
  "description": "Default permissions for TracePilot",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "tracepilot:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "log:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/*" }, { "url": "https://api.github.com/*" }]
    },
    "process:allow-restart",
    "updater:default"
  ]
}
