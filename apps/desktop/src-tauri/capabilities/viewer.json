{
  "$schema": "../gen/schemas/windows-schema.json",
  "identifier": "viewer",
  "description": "Permission set for viewer (pop-out session detail) windows. Originally read-only (Phase 1A.1 of tech-debt plan), now also allowlists SDK steering commands so popouts can drive their session — same single-Client backend, single-user app. Still excludes: dialog, opener, process, updater, notification, factory_reset, save_config, launch_session, skills_*, mcp_*, task_* (those remain main-window only). See docs/adr/0002-tauri-capability-scoping.md.",
  "windows": ["viewer-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-unminimize",
    "log:default",

    "tracepilot:allow-list-sessions",
    "tracepilot:allow-get-session-detail",
    "tracepilot:allow-get-session-turns",
    "tracepilot:allow-get-session-events",
    "tracepilot:allow-get-session-incidents",
    "tracepilot:allow-get-session-todos",
    "tracepilot:allow-get-session-checkpoints",
    "tracepilot:allow-get-session-plan",
    "tracepilot:allow-get-shutdown-metrics",
    "tracepilot:allow-check-session-freshness",
    "tracepilot:allow-is-session-running",
    "tracepilot:allow-get-tool-result",
    "tracepilot:allow-check-config-exists",
    "tracepilot:allow-get-config",
    "tracepilot:allow-close-session-window",

    "tracepilot:allow-session-list-files",
    "tracepilot:allow-session-read-file",
    "tracepilot:allow-session-read-sqlite",

    "tracepilot:allow-sdk-status",
    "tracepilot:allow-sdk-hydrate",
    "tracepilot:allow-sdk-list-sessions",
    "tracepilot:allow-sdk-list-models",
    "tracepilot:allow-sdk-get-auth-status",
    "tracepilot:allow-sdk-get-quota",
    "tracepilot:allow-sdk-get-foreground-session",
    "tracepilot:allow-sdk-set-foreground-session",
    "tracepilot:allow-sdk-resume-session",
    "tracepilot:allow-sdk-send-message",
    "tracepilot:allow-sdk-abort-session",
    "tracepilot:allow-sdk-destroy-session",
    "tracepilot:allow-sdk-unlink-session",
    "tracepilot:allow-sdk-set-session-mode",
    "tracepilot:allow-sdk-set-session-model"
  ]
}
